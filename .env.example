# ─────────────────────────────────────────────────────────────────────────────
# Addressable — address lookup (autocomplete + geocoding)
#
# These variables override config/byte5-addressable.php at runtime. All are
# optional except the API key, which is required to use the lookup feature.
# ─────────────────────────────────────────────────────────────────────────────

# Which lookup driver to use. Default: google
ADDRESSABLE_LOOKUP_PROVIDER=google

# Google Maps Platform server-side API key (requires "Places API (New)" enabled).
# Required for AddressLookup::suggest() / details(). Keep it server-side only.
ADDRESSABLE_LOOKUP_GOOGLE_KEY=

# Places languageCode for results, e.g. "de" or "en".
# Blank = falls back to the application locale (app()->getLocale()).
ADDRESSABLE_LOOKUP_GOOGLE_LANGUAGE=

# Region bias (regionCode), e.g. "DE". Blank = no bias.
ADDRESSABLE_LOOKUP_GOOGLE_REGION=

# Restrict suggestions to a single ISO 3166-1 alpha-2 country code, e.g. "DE".
# Blank = no restriction. For multiple countries, set an array in the config file.
ADDRESSABLE_LOOKUP_GOOGLE_COUNTRY=

# ─────────────────────────────────────────────────────────────────────────────
# Address validation (AddressValidator::validate())
# ─────────────────────────────────────────────────────────────────────────────

# Which validation driver to use. Default: google
ADDRESSABLE_VALIDATION_PROVIDER=google

# Google server-side API key (requires "Address Validation API" enabled — a separate
# SKU). May be the same key as the lookup one if both APIs are enabled on it.
ADDRESSABLE_VALIDATION_GOOGLE_KEY=

# How the AddressExists validation rule reacts when the provider is unreachable.
# false (default): surface the error. true: let the address through (degrade gracefully).
ADDRESSABLE_VALIDATION_PASS_ON_OUTAGE=false

# Note: structural options (models.address, table_names, column_names, type_enum)
# are configured directly in the published config file, not via env.
